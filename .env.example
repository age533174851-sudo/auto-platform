# ═══════════════════════════════════════════════════════════════
# TRAIGO Environment Variables — copy to .env.local to run locally
# ═══════════════════════════════════════════════════════════════

# ── App URL (required for /api/market aggregator) ─────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Supabase (optional — required for auth/DB features) ───────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Market Data (optional — mock fallback if empty) ───────────
# Polygon.io   https://polygon.io/dashboard
POLYGON_API_KEY=

# Finnhub      https://finnhub.io/dashboard
FINNHUB_API_KEY=

# ── Exchange API Keys (optional — required for live trading) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# KIS Open API https://apiportal.koreainvestment.com
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=

# ── Commodities (optional) ────────────────────────────────────
COMMODITY_API_KEY=

# ── Alerts / Telegram (optional) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_SECRET=

# ── Exchange encryption key (generate: openssl rand -hex 16) ──
EXCHANGE_ENCRYPTION_KEY=
