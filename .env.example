# ═══════════════════════════════════════════════════════════════
# TRAIGO — Environment Variables
# Copy to .env.local for local development
# All values below must be set in Vercel → Project Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED) ──────────────────────────────────────
# Available to browser (client components)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (API routes) — NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Exchange API key encryption (REQUIRED if exchange connect is used) ──
# 32-character random string — openssl rand -hex 16
# Falls back to SUPABASE_SERVICE_ROLE_KEY if not set (not recommended)
EXCHANGE_ENCRYPTION_KEY=your-32-char-encryption-key-here

# ── OpenAI (optional — AI chat features) ────────────────────
OPENAI_API_KEY=sk-...

# ── Market data APIs (optional — falls back to mock data) ───
POLYGON_API_KEY=your-polygon-key
ALPHA_VANTAGE_API_KEY=your-alphavantage-key
FINNHUB_API_KEY=your-finnhub-key
NEWS_API_KEY=your-newsapi-key

# ── Safety / Alerts (optional — Telegram bot notifications) ─
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
ADMIN_SECRET=your-admin-secret-token

# ── TradingView webhook (optional) ──────────────────────────
TRADINGVIEW_WEBHOOK_SECRET=your-webhook-secret

# ── NOT REQUIRED (registered in Vercel but not used in code) ─
# GEMINI_API_KEY    — not referenced in current code
# TWELVE_API_KEY    — not referenced in current code
# Firebase keys     — not referenced in current code
