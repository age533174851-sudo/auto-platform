# ═══════════════════════════════════════════════════════════════
# TRAIGO — Environment Variables
# Copy to .env.local, fill values, never commit real values
# ═══════════════════════════════════════════════════════════════

# ── Supabase (Auth + DB) ──────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...          # public anon key — OK to expose
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # ⚠️ SERVER-ONLY — never prefix NEXT_PUBLIC_

# ── OpenAI (AI chat / analysis) ───────────────────────────────
# https://platform.openai.com/api-keys
# Model used: gpt-4o-mini (fast + affordable)
OPENAI_API_KEY=sk-...                         # ⚠️ SERVER-ONLY

# ── Polygon.io (US stocks) ────────────────────────────────────
# https://polygon.io — free tier: 5 req/min
POLYGON_API_KEY=...                           # ⚠️ SERVER-ONLY

# ── Finnhub (Economic calendar / earnings / news) ─────────────
# https://finnhub.io — free tier: 60 req/min
FINNHUB_API_KEY=...                           # ⚠️ SERVER-ONLY

# ── NewsAPI (Global financial news) ───────────────────────────
# https://newsapi.org — free tier: 100 req/day (dev only)
NEWS_API_KEY=...                              # ⚠️ SERVER-ONLY

# ── Alpha Vantage (Technical indicators / backup candles) ─────
# https://www.alphavantage.co — free tier: 25 req/day
ALPHA_VANTAGE_API_KEY=...                     # ⚠️ SERVER-ONLY

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# VERCEL DEPLOYMENT
# ═══════════════════════════════════════════════════════════════
# Add all keys at: Project → Settings → Environment Variables
# ⚠️ Keys WITHOUT NEXT_PUBLIC_ are server-only (API routes only)
# ⚠️ Keys WITH NEXT_PUBLIC_ are safe for browser bundle
#
# Crypto: Binance public API — no key needed
# Korean stocks: KRX data via mock (real KIS API optional)
# ═══════════════════════════════════════════════════════════════

# ── Exchange API Encryption ───────────────────────────────────
# Random 64-char hex string for AES-256 encryption of API secrets
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXCHANGE_ENCRYPTION_KEY=your-64-char-hex-key-here       # ⚠️ SERVER-ONLY

# ── Auto-trading Safety ───────────────────────────────────────
# TradingView webhook secret (set in TradingView alert message as "code":"xxx")
TRADINGVIEW_WEBHOOK_SECRET=your-secret-here      # ⚠️ SERVER-ONLY

# Admin kill switch secret
ADMIN_SECRET=traigo-admin-change-me              # ⚠️ SERVER-ONLY

# Telegram notification fallback
TELEGRAM_BOT_TOKEN=                              # ⚠️ SERVER-ONLY
TELEGRAM_CHAT_ID=                                # ⚠️ SERVER-ONLY
