# ═══════════════════════════════════════════════════════════════
# TRAIGO Environment Variables — copy to .env.local
# All keys are server-side only (no NEXT_PUBLIC_ prefix)
# ═══════════════════════════════════════════════════════════════

# ── App URL (required for /api/market aggregator) ─────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_MODE=production

# ── Site URL for auth email redirects (required for prod) ─────
# 이메일 인증 / 비밀번호 재설정 링크가 이 도메인의 /auth/callback 으로 옵니다.
# 미설정 시 window.location.origin 사용 (개발 환경에서만 안전)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── Supabase (optional — auth/DB features) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Market Data Providers (all optional — mock fallback) ──────
POLYGON_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
EODHD_API_KEY=
NEWS_API_KEY=
EXCHANGE_RATE_API_KEY=
COMMODITY_API_KEY=

# ── FinancialJuice (widget mode = no key needed) ──────────────
FINANCIALJUICE_MODE=widget
FINANCIALJUICE_API_KEY=

# ── AI / Briefing ─────────────────────────────────────────────
OPENAI_API_KEY=

# ── Exchange Trading (optional — real orders) ─────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=

# ── Alerts / Telegram (optional) ──────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_SECRET=
# Comma-separated list of emails that get auto-promoted to admin on first login.
# Example: ADMIN_EMAILS=you@example.com,partner@example.com
ADMIN_EMAILS=

# ── Encryption (generate: openssl rand -hex 16) ───────────────
EXCHANGE_ENCRYPTION_KEY=
