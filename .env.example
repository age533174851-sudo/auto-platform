# ═══════════════════════════════════════════════════════════════
# TRAIGO Environment Variables — copy to .env.local
# All keys are server-side only (no NEXT_PUBLIC_ prefix)
# ═══════════════════════════════════════════════════════════════

# ── App URL (required for /api/market aggregator) ─────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_MODE=production

# ── Supabase (optional — auth/DB features) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Market Data Providers (all optional — mock fallback) ──────
POLYGON_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
EODHD_API_KEY=
NEWS_API_KEY=
EXCHANGE_RATE_API_KEY=
COMMODITY_API_KEY=

# ── FinancialJuice (widget mode = no key needed) ──────────────
FINANCIALJUICE_MODE=widget
FINANCIALJUICE_API_KEY=

# ── AI / Briefing ─────────────────────────────────────────────
OPENAI_API_KEY=

# ── Exchange Trading (optional — real orders) ─────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=

# ── Alerts / Telegram (optional) ──────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_SECRET=

# ── Encryption (generate: openssl rand -hex 16) ───────────────
EXCHANGE_ENCRYPTION_KEY=
