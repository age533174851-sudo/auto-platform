# ══════════════════════════════════════════════════════════════════
# TRAIGO .env.local — Copy to .env.local and fill in your API keys
# ══════════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED for auth/DB) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Market Data ───────────────────────────────────────────────────
# Polygon.io — US stocks real-time (free tier available)
# Get at: https://polygon.io/dashboard
NEXT_PUBLIC_POLYGON_API_KEY=

# Finnhub — Economic calendar, news, quotes (free tier available)  
# Get at: https://finnhub.io/dashboard
NEXT_PUBLIC_FINNHUB_API_KEY=

# Alpha Vantage — US/global stock data (free tier available)
# Get at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ── Korean Market ─────────────────────────────────────────────────
# KIS Open API — 한국투자증권 실시간 주가 (무료 신청)
# 신청: https://apiportal.koreainvestment.com
KIS_APP_KEY=
KIS_APP_SECRET=

# ── Commodities ───────────────────────────────────────────────────
# Commodities API — Gold, Oil, Natural Gas prices
# Get at: https://commodities-api.com
COMMODITY_API_KEY=

# ── AI Features ──────────────────────────────────────────────────
# OpenAI — AI chat and analysis
OPENAI_API_KEY=

# ── Exchange Encryption ───────────────────────────────────────────
# Required for exchange API key storage (generate with: openssl rand -hex 16)
EXCHANGE_ENCRYPTION_KEY=

# ── Alerts (Optional) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
