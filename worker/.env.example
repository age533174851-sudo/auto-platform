# TRAIGO Worker — Railway 환경변수

# Supabase (service role — DB 전체 권한, 절대 클라이언트 노출 금지)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 거래소 API secret 복호화 키
# ★ Vercel의 EXCHANGE_ENCRYPTION_KEY와 반드시 동일한 값 ★
# (ENCRYPTION_KEY / EXCHANGE_ENCRYPTION_KEY 둘 중 아무 이름으로 넣어도 인식)
ENCRYPTION_KEY=
# EXCHANGE_ENCRYPTION_KEY=

# Upstash Redis (job/action 락 — 미설정 시 Supabase worker_lock 폴백)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Telegram (Vercel과 동일 값)
TELEGRAM_MONEY_BOT_TOKEN=
TELEGRAM_MONEY_CHAT_ID=
TELEGRAM_SYSTEM_BOT_TOKEN=
TELEGRAM_SYSTEM_CHAT_ID=
# (듀얼봇 미설정 시 폴백)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 루프 주기(초), 워커 식별자
WORKER_POLL_SEC=3
WORKER_ID=worker-1
